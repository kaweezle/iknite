{
  "[terraform]": {
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "opentofu.vscode-opentofu",
    "editor.formatOnSave": true
  },
  "[hcl]": {
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "fredwangwang.vscode-hcl-format",
    "editor.formatOnSave": true
  },
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [80, 120],
  "go.formatTool": "default",
  "shellcheck.exclude": ["3043"],
  "makefile.makefilePath": "GNUmakefile",
  "makefile.configureOnOpen": false,
  "files.associations": {
    "*.gotmpl": "helm"
  },
  "chat.tools.terminal.autoApprove": {
    "go": true,
    "golangci-lint": true,
    "pre-commit": true,
    "git add": true,
    "/home/alpine/go/bin/mockery": true,
    "make": true,
    "jq": true,
    "gofmt": true
  },
  "go.coverageDecorator": {
    "type": "gutter"
  },
  "go.coverOnSingleTestFile": true,
  "go.coverOnSingleTest": true,
  "go.inlayHints.assignVariableTypes": false,
  "go.lintTool": "golangci-lint",
    "go.testFlags": [
        "-coverpkg=./..."
    ],
    "go.lintOnSave": "package"

}
