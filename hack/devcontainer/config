# SSH configuration for iknite VMs with fixed host keys.
# The VM always presents the same SSH host key (configured via cloud-init),
# which is pre-trusted in ~/.ssh/iknite_known_hosts.
# Connect using: ssh -o Hostname=<VM_IP> iknite-vm
Host iknite-vm
    StrictHostKeyChecking yes
    UserKnownHostsFile ~/.ssh/iknite_known_hosts
    IdentityFile ~/.ssh/iknite
    User root
    Port 22
